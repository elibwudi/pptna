# ========================================
# API密钥配置 (请替换为您的实际密钥)
# ========================================
GEMINI_API_KEY="your_gemini_api_key_here"
DEEPSEEK_API_KEY="your_deepseek_api_key_here"
DASHSCOPE_API_KEY="your_dashscope_api_key_here"

# ========================================
# 应用安全配置
# ========================================
# Flask会话密钥 (请使用: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY="your_secret_key_here"

# Ollama服务地址 (本地部署的AI模型)
OLLAMA_BASE_URL="http://10.255.1.103:11434/v1"

# 运行环境 (development/production)
FLASK_ENV="production"
FLASK_DEBUG="false"

# ========================================
# 管理员密码配置 (bcrypt哈希)
# ========================================
# 原始密码: 请设置强密码
# 生成方式: python -c "import bcrypt; print(bcrypt.hashpw(b'你的密码', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH="your_bcrypt_hash_here"
